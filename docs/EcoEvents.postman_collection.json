{
	"info": {
		"_postman_id": "ecoevents-api-collection",
		"name": "EcoEvents API",
		"description": "Complete collection of endpoints for the EcoEvents API.\n\n**Recommended workflow:**\n1. Register a user (POST /api/users)\n2. Log in (POST /api/users/login) → copy the token\n3. Paste the token into the collection variable `token`\n4. Test the remaining authenticated endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000/api",
			"type": "string"
		}
	],
